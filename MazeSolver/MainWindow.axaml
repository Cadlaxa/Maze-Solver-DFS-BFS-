<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MazeSolver.MainWindow"
        Title="Maze Solver" Width="900" Height="650">
    
    <DockPanel>
        <Expander Background="#292929" DockPanel.Dock="Top" Header="Settings &amp; Controls" IsExpanded="True" FontWeight="Bold"
                  HorizontalAlignment="Stretch" Foreground="White">
            
            <Border Padding="0" Background="#292929">
                <StackPanel Orientation="Vertical" Spacing="10">
                    
                    <!-- ROW 1: Master Controls -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Button Name="GenerateBtn" Content="Generate Maze" Click="OnGenerateClick" Background="#4CAF50"/>
                        
                        <TextBlock Text="Size:" VerticalAlignment="Center" Foreground="White"/>
                        <Slider Name="DifficultySlider" Minimum="10" Maximum="100" Value="25" Width="150" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        
                        <Button Name="StartBtn" Content="Start" Click="OnStartClick" Background="#4CAF50" Foreground="White"/>
                        <Button Name="StopBtn" Content="Stop" Click="OnStopClick" Background="#F44336" Foreground="White"/>
                    </StackPanel>

                    <!-- ROW 2: Layout & Algorithm Selections -->
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="Layout:" VerticalAlignment="Center" Foreground="White"/>
                        <ComboBox Name="LayoutCombo" SelectedIndex="1" SelectionChanged="OnLayoutChanged" Width="100">
                            <ComboBoxItem>1 Grid</ComboBoxItem>
                            <ComboBoxItem>2 Grids</ComboBoxItem>
                            <ComboBoxItem>4 Grids</ComboBoxItem>
                        </ComboBox>
                        
                        <TextBlock Text="|" VerticalAlignment="Center" Foreground="Gray" Margin="10,0"/>

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Grid 1:" VerticalAlignment="Center" Foreground="#80FFFF" FontWeight="Bold"/>
                            <ComboBox Name="Algo1" SelectedIndex="0" Width="100"><ComboBoxItem>BFS</ComboBoxItem><ComboBoxItem>DFS</ComboBoxItem><ComboBoxItem>Dijkstra</ComboBoxItem><ComboBoxItem>A* Search</ComboBoxItem></ComboBox>
                        </StackPanel>

                        <StackPanel Name="PanelAlgo2" Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Grid 2:" VerticalAlignment="Center" Foreground="#FF85FF" FontWeight="Bold"/>
                            <ComboBox Name="Algo2" SelectedIndex="1" Width="100"><ComboBoxItem>BFS</ComboBoxItem><ComboBoxItem>DFS</ComboBoxItem><ComboBoxItem>Dijkstra</ComboBoxItem><ComboBoxItem>A* Search</ComboBoxItem></ComboBox>
                        </StackPanel>

                        <StackPanel Name="PanelAlgo3" Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Grid 3:" VerticalAlignment="Center" Foreground="#80FF80" FontWeight="Bold"/>
                            <ComboBox Name="Algo3" SelectedIndex="2" Width="100"><ComboBoxItem>BFS</ComboBoxItem><ComboBoxItem>DFS</ComboBoxItem><ComboBoxItem>Dijkstra</ComboBoxItem><ComboBoxItem>A* Search</ComboBoxItem></ComboBox>
                        </StackPanel>

                        <StackPanel Name="PanelAlgo4" Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Grid 4:" VerticalAlignment="Center" Foreground="#C587FF" FontWeight="Bold"/>
                            <ComboBox Name="Algo4" SelectedIndex="3" Width="100"><ComboBoxItem>BFS</ComboBoxItem><ComboBoxItem>DFS</ComboBoxItem><ComboBoxItem>Dijkstra</ComboBoxItem><ComboBoxItem>A* Search</ComboBoxItem></ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <!-- ROW 3: Independent Timers -->
                    <StackPanel Orientation="Horizontal" Spacing="25" HorizontalAlignment="Center">
                        <TextBlock Name="Timer1" Text="Grid 1: 0.0s" Foreground="#80FFFF" FontWeight="Bold"/>
                        <TextBlock Name="Timer2" Text="Grid 2: 0.0s" Foreground="#FF85FF" FontWeight="Bold"/>
                        <TextBlock Name="Timer3" Text="Grid 3: 0.0s" Foreground="#80FF80" FontWeight="Bold"/>
                        <TextBlock Name="Timer4" Text="Grid 4: 0.0s" Foreground="#C587FF" FontWeight="Bold"/>
                    </StackPanel>
                    
                </StackPanel>
            </Border>
            
        </Expander>

        <!-- Main Display Area -->
        <UniformGrid Name="MasterGrid" Rows="2" Columns="2" Margin="5">
            
            <DockPanel Name="Container1" Margin="5">
                <TextBlock Name="Title1" DockPanel.Dock="Top" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Cyan" Margin="0,0,0,5"/>
                <Border Name="MazeBorder1" BorderBrush="#555555" BorderThickness="4" CornerRadius="2">
                    <UniformGrid Name="MazeGrid1" Background="Black"/>
                </Border>
            </DockPanel>
            
            <DockPanel Name="Container2" Margin="5">
                <TextBlock Name="Title2" DockPanel.Dock="Top" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Magenta" Margin="0,0,0,5"/>
                <Border Name="MazeBorder2" BorderBrush="#555555" BorderThickness="4" CornerRadius="2">
                    <UniformGrid Name="MazeGrid2" Background="Black"/>
                </Border>
            </DockPanel>
            
            <DockPanel Name="Container3" Margin="5">
                <TextBlock Name="Title3" DockPanel.Dock="Top" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Lime" Margin="0,0,0,5"/>
                <Border Name="MazeBorder3" BorderBrush="#555555" BorderThickness="4" CornerRadius="2">
                    <UniformGrid Name="MazeGrid3" Background="Black"/>
                </Border>
            </DockPanel>
            
            <DockPanel Name="Container4" Margin="5">
                <TextBlock Name="Title4" DockPanel.Dock="Top" HorizontalAlignment="Center" FontWeight="Bold" Foreground="BlueViolet" Margin="0,0,0,5"/>
                <Border Name="MazeBorder4" BorderBrush="#555555" BorderThickness="4" CornerRadius="2">
                    <UniformGrid Name="MazeGrid4" Background="Black"/>
                </Border>
            </DockPanel>
            
        </UniformGrid>
        
    </DockPanel>
</Window>